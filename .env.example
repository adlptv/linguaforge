# Database
DATABASE_URL="file:./dev.db"

# API Key for CLI auth
LINGUAFORGE_API_KEY="lf_dev_secret_key_change_in_production"

# Machine Translation API Key (e.g., DeepL, Google Translate)
MT_API_KEY=""

# CORS
CORS_ORIGIN="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="900000"

# Environment
NODE_ENV="development"
